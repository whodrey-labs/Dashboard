APP_NAME=dashboard

# Local dev
FRONTEND_DEV_PORT=5173
BACKEND_DEV_PORT=4000

# Production / homelab
APP_URL=https://dashboard.whodrey.com
HOST_PORT=3095

# Backend
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_TOKEN_FILE=.tokens/google-calendar-token.json

# Secret values are injected from GitHub repository/deployment secrets.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_STATE_SECRET=

# Backend runtime
NODE_ENV=development
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.events.readonly https://www.googleapis.com/auth/calendar.calendarlist.readonly
